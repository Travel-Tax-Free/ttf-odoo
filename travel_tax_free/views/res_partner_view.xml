<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ttf_partner_form_view" model="ir.ui.view">
        <field name="name">res_partner_common_form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <field name="function" position="after">
                <field name="date_birthdate" attrs="{'invisible': [('is_company','=', True)]}" />
                <field name="passport" attrs="{'invisible': [('is_company','=', True)]}" />
                <field name="passport_country_id" attrs="{'invisible': [('is_company','=', True)]}" />
            </field>
        </field>
    </record>
</odoo>

