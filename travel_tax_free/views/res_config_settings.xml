<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_taxfree_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.taxfree</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="95"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Travel Tax Free" string="Travel Tax Free" name="travel_tax_free">
                    
                    <block title="Configuración para Travel Tax Free" id="taxfree_config_base">
                        <setting id="taxfree_url_setting" help="URL de la API para la conexión">
                            <field name="taxfree_url"/>
                        </setting>
                        
                        <setting id="taxfree_users_setting">
                            <div class="mt-2">
                                <button type='object' name='open_users' string="Lista de usuarios" class="btn-primary"/>
                            </div>
                        </setting>
                    </block>

                    <block title="Opciones" id="taxfree_options">
                        <setting id="taxfree_attach_setting" help="Adjuntar el tax free al documento (se aconseja valor a True)">
                            <field name="taxfree_attach"/>
                        </setting>

                        <setting id="taxfree_serial_setting" help="Enviar número de serie del producto si existe.">
                            <field name="taxfree_serial"/>
                        </setting>

                        <setting id="taxfree_format_setting" title="Formato de impresión por defecto">
                            <field name="taxfree_format" required="1" />
                        </setting>

                        <setting id="taxfree_category_setting" title="Categoría cliente creado en TPV">
                            <field name="taxfree_category_id"/>
                        </setting>

                        <setting id="taxfree_email_setting" help="Email obligatorio en el cliente POS (requiere reiniciar POS)">
                            <field name="taxfree_email_required"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>