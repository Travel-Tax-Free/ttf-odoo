<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <t t-name="template_taxfree_pos" t-inherit="point_of_sale.ClientDetailsEdit" t-inherit-mode="extension">
        <xpath expr="//div[@class='client-details-left']" position="inside">
            <div class='client-detail'>
                <span class='label'>Pasaporte</span>
                <input class='detail client-passport' name='passport' t-att-value='partner.passport || ""'
                       placeholder="Pasaporte"></input>
            </div>
            <br/>
            <div class='client-detail'>
                <span><strong>País de residencia igual al país de pasaporte </strong></span>
                <input type='checkbox' class='detail client-checkbox' style='max-width: 15px;' id='same_country'
                name='same_country' t-att-checked="partner.passport_country_id ? None : 'checked'"
                onchange="document.getElementById('passport_country').style.display=(this.checked)?'none':'block';"></input>
            </div>
            <br/>
            <t t-if="!partner.passport_country_id">
                <script>
                    $("#passport_country").hide();
                </script>
            </t>
            <div id='passport_country' class='client-detail'>
                <span class='label'>País de pasaporte</span>
                <select class='detail client-passport-country needsclick' name='passport_country_id' id='pass_param'>
                    <option id="empty" value=''>None</option>
                    <t t-foreach='widget.pos.countries' t-as='country'>
                        <option t-att-value='country.id' t-att-selected="partner.passport_country_id ? ((country.id === partner.passport_country_id[0]) ? true : undefined) : undefined">
                            <t t-esc='country.name'/>
                        </option>
                    </t>
                </select>
            </div>
            <script>
                $(function() {
                    if ($("#pass_param").val() == "" || $("#pass_param").val() == $("#country_param").val()) {
                        $("#pass_param").val($("#country_param").val());
                        $("#passport_country").hide();
                        $("#same_country").prop("checked", true);
                    }
                });

                $("#country_param").change(function() {
                    if ($("#same_country").is(':checked')) {
                        $("#pass_param").val($("#country_param").val());
                    }
                });

                $("#same_country").click(function() {
                    if (this.checked) {
                        $("#pass_param").val($("#country_param").val());
                        $("#passport_country").hide();
                    } else {
                        $("#passport_country").show();
                    }
                });
            </script>
        </xpath>
        <xpath expr="//div[@class='client-details-right']" position="inside">
            <div class='client-detail'>
                <span class='label'>Fecha de nacimiento</span>
                <input type="date" class='detail client-birthdate' name='date_birthdate'
                       t-att-value='partner.date_birthdate || ""' placeholder="mm/dd/yyyy"></input>
            </div>
        </xpath>
        <xpath expr="//div[@class='button save']" position="before">
            <div class='button scan-passport'>
                <i class='fa fa-qrcode' role="img" aria-label="Scanner" title="Scanner"/>
            </div>
        </xpath>
        <xpath expr="//select[@class='detail client-address-country needsclick']" position="replace">
                        <div style="padding: 0px 0px 4px 0px; width: 340px; display: inline-block;">
                        <select class='detail client-address-country needsclick' name='country_id' id='country_param'>
                            <option value=''>None</option>
                            <t t-foreach='widget.pos.countries' t-as='country'>
                                <option t-att-value='country.id' t-att-selected="partner.country_id ? ((country.id === partner.country_id[0]) ? true : undefined) : undefined">
                                    <t t-esc='country.name'/>
                                </option>
                            </t>
                        </select></div>
            <t t-if='widget.pos.config.experimental_country'>
                <script>
                    var $select_ac = $('select[name="country_id"]').selectize();
                    var $select_pc = $('select[name="passport_country_id"]').selectize();

                    $(function() {
                        $('div.selectize-control').removeClass('client-details-contents detail');
                        $('div.selectize-dropdown').removeClass('client-details-contents detail');
                    });

                    $(function() {
                        if ($("#pass_param").val() == "" || $("#pass_param").val() == $("#country_param").val()) {
                            $select_pc[0].selectize.setValue($("#country_param").val());
                            $("#passport_country").hide();
                            $("#same_country").prop("checked", true);
                        }
                    });

                    $("#country_param").change(function() {
                        if ($("#same_country").is(':checked')) {
                            $select_pc[0].selectize.setValue($("#country_param").val());
                        }
                    });

                    $("#same_country").click(function() {
                        if (this.checked) {
                            $select_pc[0].selectize.setValue($("#country_param").val());
                            $("#passport_country").hide();
                        } else {
                            $("#passport_country").show();
                            $("#empty").hide();
                        }
                    });
                </script>
            </t>
        </xpath>
    </t>

    <t t-name="template_taxfree_payment_screen" t-inherit="point_of_sale.PaymentScreenWidget"
       t-inherit-mode="extension">
        <xpath expr="//div[@class='button js_email']" position="before">
            <t t-if='widget.pos.config.travel_user_id'>
                <t t-if='widget.pos.config.module_account'>
                    <t t-if='widget.pos.get_order()'>
                        <div class='button js_taxfree'>
                            <i class='fa fa-suitcase'/>
                            Factura + Tax Free
                        </div>
                    </t>
                </t>
            </t>

        </xpath>
    </t>

    <t t-name="template_taxfree_print_taxfree" t-inherit="point_of_sale.ReceiptScreenWidget"
       t-inherit-mode="extension">
        <xpath expr="//div[@class='button print']" position="after">
            <div class="button print_taxfree">
                <i class='fa fa-print'></i>
                Imprimir tax free
            </div>
        </xpath>
    </t>


</odoo>
