<?xml version="1.0" encoding="UTF-8" ?>
<templates id="template" xml:space="preserve">
    <t t-name="travel_tax_free.PaymentScreenButtons" t-inherit="point_of_sale.PaymentScreenButtons" t-inherit-mode="extension">
        
        <xpath expr="//button[hasclass('js_invoice')]" position="after">
            <button class="button js_taxfree btn btn-secondary btn-lg d-flex justify-content-between align-items-baseline w-100 w-md-50 lh-lg"
                    t-att-class="{ 'highlight active text-action border-primary': currentOrder.is_to_taxfree() }"
                    t-on-click="click_taxfree">
                <span>
                    <i class="fa fa-suitcase me-2" />
                    Factura + Tax Free
                </span>
                <i class="fa me-2" t-attf-class="{{ currentOrder.is_to_taxfree() ? 'fa-check-square text-action' : 'fa-square-o' }}" />
            </button>
        </xpath>
    </t>
</templates>