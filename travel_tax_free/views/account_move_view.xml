<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="account_move_common_form" model="ir.ui.view">
            <field name="name">account_move_common_form</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <field name="ref" position="after">
                    <field name="taxfree" readonly="1" invisible="taxfree == False"/>
                    <field name="taxfree_id" readonly="1" invisible="taxfree_id == False"/>
                </field>

            </field>
        </record>


        <record id="account_move_common_form2" model="ir.ui.view">
            <field name="name">account_move_common_form</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <button name="button_draft" position="after">
                    <button
                            name="remove_taxfree"
                            type="object"
                            string="Desvincular taxfree"
                            confirm="¿Está seguro que quiere desvincular el taxfree? Recuerde que tiene que notificar la cancelación a Travel Tax Free para su cancelación definitiva en la AEAT"
                            invisible="taxfree == False"
                    />
                </button>

            </field>

        </record>
<!--
        <record id="account_move_line_common_form" model="ir.ui.view">
            <field name="name">account_move_line_common_form</field>
            <field name="model">account.move.line</field>
            <field name="inherit_id" ref="account.view_move_line_form"/>
            <field name="arch" type="xml">
                <field name="name" position="after">
                    <field name="serial"/>
                </field>

            </field>
        </record>
-->

    </data>
</odoo>