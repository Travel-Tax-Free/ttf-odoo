<?xml version="1.0" encoding="UTF-8" ?>
<templates id="template" xml:space="preserve">

    <t t-inherit="point_of_sale.PaymentScreen" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('payment-controls')]" position="inside">
            <div class='button js_taxfree' t-on-click="click_taxfree">
                <i class='fa fa-suitcase' role="img" aria-label="Invoice Taxfree Button" title="Invoice Taxfree Button" />
                Factura + Tax Free
            </div>
        </xpath>
    </t>

</templates>
