<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_config_common_form" model="ir.ui.view">
        <field name="name">pos.config.form.inherit.taxfree</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                
                <group string="Travel Tax Free" name="taxfree_group">
                    <field name="travel_user_id" placeholder="Seleccione usuario..."/>
                </group>

            </xpath>
        </field>
    </record>
</odoo>