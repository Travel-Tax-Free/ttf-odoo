<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-inherit="point_of_sale.ReceiptScreen" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('receipt-options')]/div[hasclass('d-flex') and hasclass('gap-1')]" position="after">
            <div t-if="currentOrder.is_to_taxfree()" class="d-flex gap-1">
                <button class="button print_taxfree btn btn-lg btn-secondary w-100 py-3"
                        t-on-click="click_print_taxfree">
                    <i class="fa fa-print me-1" role="img"
                       aria-label="Print Taxfree Button"
                       title="Print Taxfree Button"/>
                    Imprimir Tax Free
                </button>
            </div>
        </xpath>
    </t>

</templates>