    </t>
    <t t-name="PartnerListScreen" t-inherit="point_of_sale.PartnerListScreen" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[hasclass('more-info')]" position="before">
            <div t-if='state.detailIsShown' class='button scan-passport' t-on-click='scan_client_details'>
                <i class='fa fa-qrcode' role="img" aria-label="Scanner" title="Scanner"/>
            </div>
