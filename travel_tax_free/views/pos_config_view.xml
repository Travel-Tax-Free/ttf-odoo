<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="pos_config_common_form" model="ir.ui.view">
            <field name="name">pos_config_common_form</field>
            <field name="model">pos.config</field>
            <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
            <field name="arch" type="xml">
                <div id="iface_invoicing" position="after">
                        <div class="col-12 col-lg-6 o_setting_box pos_taxfree">
                            <div class="o_setting_left_pane">
                                <field name='taxfree'/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="taxfree"/>
                                <div class="text-muted">
                                    Permite realizar tax free. Requiere la opción de contabilidad activa
                                </div>
                            </div>
                        </div>
                </div>

            </field>
        </record>

    </data>
</odoo>